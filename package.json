{
  "name": "sf-org-list",
  "displayName": "Salesforce Org List",
  "description": "Displays a list of authenticated orgs for quick logins",
  "version": "2.1.0",
  "publisher": "dennisgrzyb",
  "repository": "https://github.com/dschibster/sfdx-org-list-vscode-extension",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "org-list",
          "title": "Org List",
          "icon": "media/cloud-stack.png"
        }
      ]
    },
    "views": {
      "org-list": [
        {
          "type": "webview",
          "id": "org-list-pinned",
          "name": "Pinned"
        },
        {
          "id": "org-list",
          "name": "Orgs"
        }
      ]
    },
    "commands": [
      {
        "command": "org-list.reload",
        "title": "Reload",
        "icon": {
          "light": "media/refresh.png",
          "dark": "media/refresh.png"
        }
      },
      {
        "command": "org-list.toggleShowHidden",
        "title": "Show/Hide Hidden Orgs",
        "icon": {
          "light": "media/hideshow.png",
          "dark": "media/hideshow.png"
        }
      },
      {
        "command": "org-list.createFolder",
        "title": "New Org Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "org.open",
        "title": "Open",
        "icon": {
          "light": "media/newwindow.png",
          "dark": "media/newwindow.png"
        }
      },
      {
        "command": "org.default",
        "title": "Set Default"
      },
      {
        "command": "org.rename",
        "title": "Change Alias"
      },
      {
        "command": "org.logout",
        "title": "Logout"
      },
      {
        "command": "org.delete",
        "title": "Delete"
      },
      {
        "command": "org.toggleHidden",
        "title": "Hide/Show Org"
      },
      {
        "command": "org.togglePin",
        "title": "Pin / Unpin",
        "icon": "$(pinned)"
      },
      {
        "command": "org.copyAuthUrl",
        "title": "Copy Auth URL"
      },
      {
        "command": "org.copyLoginCommand",
        "title": "Copy Login Command"
      },
      {
        "command": "org.assignToFolder",
        "title": "Move to Folder…"
      },
      {
        "command": "org.removeFromFolder",
        "title": "Remove from Folder"
      },
      {
        "command": "orgFolder.rename",
        "title": "Rename Folder"
      },
      {
        "command": "orgFolder.delete",
        "title": "Delete Folder"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "org-list.reload",
          "when": "view == org-list",
          "group": "navigation"
        },
        {
          "command": "org-list.toggleShowHidden",
          "when": "view == org-list",
          "group": "navigation"
        },
        {
          "command": "org-list.createFolder",
          "when": "view == org-list",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "org.open",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/",
          "group": "inline"
        },
        {
          "command": "org.togglePin",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/",
          "group": "inline"
        },
        {
          "command": "org.default",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/"
        },
        {
          "command": "org.rename",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/"
        },
        {
          "command": "org.logout",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch)-org/"
        },
        {
          "command": "org.delete",
          "when": "view == org-list && viewItem =~ /^scratch-org/"
        },
        {
          "command": "org.toggleHidden",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/"
        },
        {
          "command": "org.copyAuthUrl",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/"
        },
        {
          "command": "org.copyLoginCommand",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org/"
        },
        {
          "command": "org.assignToFolder",
          "when": "view == org-list && viewItem =~ /^(dev-hub|non-scratch|scratch)-org$/"
        },
        {
          "command": "org.removeFromFolder",
          "when": "view == org-list && viewItem =~ /-in-folder$/"
        },
        {
          "command": "orgFolder.rename",
          "when": "view == org-list && viewItem == org-folder"
        },
        {
          "command": "orgFolder.delete",
          "when": "view == org-list && viewItem == org-folder"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.9.2",
    "vscode-test": "^1.6.1"
  },
  "dependencies": {
    "@vscode/vsce": "^3.6.0",
    "vsce": "^2.15.0"
  }
}
